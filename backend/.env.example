# ============================================
# ManifestoCross - Variables de Entorno
# ============================================
# Copia este archivo a .env y configura los valores

# Aplicación
APP_NAME=ManifestoCross
VERSION=0.1.0
DEBUG=True

# Servidor
HOST=0.0.0.0
PORT=8005

# Base de datos PostgreSQL
# Usa puerto 5435 para evitar conflictos con otras instalaciones
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/manifestocross

# ElasticSearch
# Usa puerto 9201 para evitar conflictos
ELASTICSEARCH_URL=http://localhost:9201
ELASTICSEARCH_INDEX=manifiestos

# MinIO / S3
# Usa puerto 9020 para API y 9021 para consola
MINIO_ENDPOINT=localhost:9020
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=manifestocross
MINIO_SECURE=False

# Redis
# Usa puerto 6382 para evitar conflictos
REDIS_URL=redis://localhost:6382/0

# Almacenamiento
UPLOAD_DIR=storage/uploads
PROCESSED_DIR=storage/processed
MAX_UPLOAD_SIZE=52428800

# JWT / Autenticación
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OCR
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGES=spa+eng
